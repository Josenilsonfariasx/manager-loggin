# Variáveis de ambiente para o stack de monitoramento
# Copie este arquivo para .env e ajuste os valores

# ─── Ambiente ─────────────────────────────────────────────
ENVIRONMENT=production

# ─── Grafana ──────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=troque_esta_senha

# ─── Loki ─────────────────────────────────────────────────
# Período de retenção dos logs (ex: 168h = 7 dias, 744h = 31 dias)
LOKI_RETENTION_PERIOD=744h
